# =============================================================================
# Algolia Movie App — environment configuration
# =============================================================================
#
# Two modes:
#
#   sandbox  — Read-only against Algolia's public `latency` demo app. Zero setup.
#              No Personalization, no custom Rules, no NeuralSearch toggle. Good
#              for trying the app shell without provisioning anything.
#
#   owned    — Your own Algolia app. Full features. Requires running
#              `pnpm provision` first to push the movies dataset and configure
#              the index.
#
# Copy this file to `.env.local` and fill in the values for your chosen mode.

# Which mode the app runs in. One of: sandbox | owned
NEXT_PUBLIC_ALGOLIA_MODE=sandbox

# -----------------------------------------------------------------------------
# Sandbox defaults (used when NEXT_PUBLIC_ALGOLIA_MODE=sandbox).
# These are Algolia's public demo credentials. Read-only.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ALGOLIA_APP_ID=latency
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=6be0576ff61c053d5f9a3225e2a90f76
# NEXT_PUBLIC_ALGOLIA_INDEX_NAME=movies

# -----------------------------------------------------------------------------
# Owned-app config (used when NEXT_PUBLIC_ALGOLIA_MODE=owned).
# Find these in https://dashboard.algolia.com/account/api-keys/all
# -----------------------------------------------------------------------------

# Public-safe: app ID identifies your Algolia application.
NEXT_PUBLIC_ALGOLIA_APP_ID=

# Public-safe: search-only API key. Restricted to search operations.
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Main movies index name.
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=movies

# Query Suggestions index (auto-created when you enable QS in the dashboard).
NEXT_PUBLIC_ALGOLIA_QS_INDEX_NAME=movies_query_suggestions

# Agent Studio agent ID. Configure the agent in the Algolia dashboard, then
# paste its ID here. Leave blank to disable the /agent route.
NEXT_PUBLIC_ALGOLIA_AGENT_ID=

# -----------------------------------------------------------------------------
# Server-only secrets. NEVER prefix with NEXT_PUBLIC_.
# These are required for provisioning scripts and the NeuralSearch toggle API.
# -----------------------------------------------------------------------------

# Admin API key. Required for `pnpm provision` and `pnpm seed-events`, and
# for the /api/neural-mode route (toggling index mode).
ALGOLIA_ADMIN_KEY=

# Analytics API key. Required for the /analytics route.
ALGOLIA_ANALYTICS_KEY=

# -----------------------------------------------------------------------------
# Optional: TMDB API key for refreshing stale poster URLs.
# -----------------------------------------------------------------------------
# The bundled Algolia movies dataset has many dead TMDB poster paths. If you
# set this and run `pnpm refresh-images`, the script will re-resolve every
# record's `image` against TMDB's current API and re-push to Algolia.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
